# Database (Supabase PostgreSQL)
# Get your pooled connection string from: Supabase Dashboard → Settings → Database → Connection string → URI (Transaction pooler)
DATABASE_URL=postgresql://postgres.[project-ref]:[your-password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# Supabase Client (for direct Supabase API access)
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Admin
ADMIN_PASSWORD=your_admin_password

# SMTP (e.g. Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_smtp_app_password
NOTIFY_EMAIL=your_email@gmail.com
